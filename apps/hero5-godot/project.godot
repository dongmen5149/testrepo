config_version=5

[application]

config/name="Hero5"
config/description="영웅서기5 (Heroes Lore 5) Android remake"
config/version="0.1.0-alpha"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
